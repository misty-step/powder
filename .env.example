# Powder local development defaults.
#
# There is no dotenv loader in powder-server -- it reads real process env
# vars only (see Config::from_env in crates/powder-server/src/main.rs).
# Load this file into your shell before running the server:
#
#   set -a; source .env; set +a
#   cargo run -p powder-server
#
# (`cp .env.example .env` alone does nothing; the values have to make it
# into the process environment.)
PORT=4000
POWDER_DB_PATH=./data/powder.db
POWDER_BIND_ADDR=127.0.0.1:4000
# Fresh unseeded boots write the one-shot key here with mode 0600 and never log raw key bytes.
POWDER_BOOTSTRAP_KEY_FILE=./data/bootstrap-key
POWDER_PUBLIC_BASE_URL=http://localhost:4000

# api-key is the safe default for authenticated ingress. Bootstrap disclosure is
# always disabled: set POWDER_BOOTSTRAP_KEY_FILE to a 0600 one-shot retrieval path.
# Use tailscale-header only when every request arrives through trusted
# Tailscale Serve or an equivalent proxy that strips spoofed identity headers.
# Use none only for local disposable development.
POWDER_AUTH_MODE=api-key

# Fail-closed read auth is the default in api-key mode: reads require a valid
# bearer key. Keyless public reads are loopback-only; non-loopback ingress stays authenticated.
POWDER_PUBLIC_READS=false

# Optional Fly Tigris/Litestream replication (bin/entrypoint.sh only; not
# read by powder-server itself). Leave unset to run without backups.
BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
POWDER_REQUIRE_LITESTREAM=0

# Tailnet instance example:
# POWDER_PUBLIC_BASE_URL=https://powder.internal

# Webhooks are NOT configured by an env var -- there is no
# POWDER_WEBHOOK_URLS. Create a subscription at runtime instead:
#   powder subscription-create --db "$POWDER_DB_PATH" --url https://example.test/hook
# See docs/self-hosting.md#webhooks.


# Local powder-mcp mutations require trusted process/session authority. These are
# never read from MCP tool arguments; actor/agent fields stay semantic labels.
POWDER_MCP_PRINCIPAL=local-operator
POWDER_MCP_ROLE=admin
